# ===== Site =====
NEXT_PUBLIC_SITE_URL=https://yuumi.quest
NEXT_PUBLIC_USE_EXAMPLE_DATA=false

# ===== Convex =====
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# ===== Riot API (server-side; also set in the Convex environment) =====
RIOT_API_KEY=

# ===== Discord OAuth (web sign-in) =====
# Application -> OAuth2; redirect URI: {SITE_URL}/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Shared secret between the Next API routes and Convex bridge mutations.
# Generate randomly (e.g. `openssl rand -hex 32`) and set the SAME value
# in the Convex environment (npx convex env set AUTH_BRIDGE_SECRET ...).
AUTH_BRIDGE_SECRET=

# ===== Stripe (1€/month Supporter subscription) =====
# Webhook endpoint: {SITE_URL}/api/stripe/webhook with events
# checkout.session.completed, invoice.paid, customer.subscription.deleted
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
