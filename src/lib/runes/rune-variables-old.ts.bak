/**
 * Rune Variables Mapping
 * Maps rune IDs to their var1, var2, var3 meanings
 * Based on League of Legends API documentation and community research
 */

export interface RuneVarInfo {
  var1?: {
    label: string;
    format:
      | 'damage'
      | 'healing'
      | 'gold'
      | 'shielding'
      | 'time'
      | 'percent'
      | 'count'
      | 'value';
    description: string;
  };
  var2?: {
    label: string;
    format:
      | 'damage'
      | 'healing'
      | 'gold'
      | 'shielding'
      | 'time'
      | 'percent'
      | 'count'
      | 'value';
    description: string;
  };
  var3?: {
    label: string;
    format:
      | 'damage'
      | 'healing'
      | 'gold'
      | 'shielding'
      | 'time'
      | 'percent'
      | 'count'
      | 'value';
    description: string;
  };
}

